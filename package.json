{
  "name": "leve",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:all": "concurrently \"npm run dev --workspace=apps/web\" \"npm run dev --workspace=apps/api\"",
    "build": "npm run build --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web",
    "lint:fix": "npm run lint:fix --workspace=apps/web",
    "typecheck": "npm run typecheck --workspace=apps/web"
  },
  "devDependencies": {
    "@types/sharp": "^0.31.1",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1051.0",
    "@prisma/client": "^5.22.0",
    "file-type": "^22.0.1",
    "lucide-react": "^1.16.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}

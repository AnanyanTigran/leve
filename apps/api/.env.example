# App
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# Database — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/leve

# Redis
REDIS_URL=redis://localhost:6379

# Session — generate with: openssl rand -hex 32
SESSION_COOKIE_SECRET=
SESSION_COOKIE_NAME=leve_sid

# AWS S3 + CloudFront
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AWS_S3_BUCKET=
AWS_CLOUDFRONT_DOMAIN=
# Key pair ID from CloudFront key groups (for signed URLs)
AWS_CLOUDFRONT_KEY_PAIR_ID=
# PEM private key — use \n for newlines in single-line env value
AWS_CLOUDFRONT_PRIVATE_KEY=

# AI Providers
FAL_API_KEY=
REPLICATE_API_TOKEN=

# Payments — Idram (required)
IDRAM_MERCHANT_ID=
IDRAM_SECRET_KEY=

# Payments — Telcell (required)
TELCELL_MERCHANT_ID=
TELCELL_SECRET_KEY=

# Amazon Translate — set to true when AWS IAM policy includes translate:TranslateText
# IAM policy snippet needed:
#   { "Sid": "TranslateAccess", "Effect": "Allow",
#     "Action": ["translate:TranslateText"], "Resource": "*" }
AWS_TRANSLATE_ENABLED=false

# OTP — SMS (optional in dev; if absent, OTP is logged to console)
OTP_SMS_API_KEY=
OTP_FROM_NUMBER=

# OTP — Email via SMTP (optional in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

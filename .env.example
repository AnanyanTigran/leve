# Single source of truth for all env vars — covers both apps/web and apps/api.
# Copy to .env at repo root. Both apps read from process.env at runtime.

# =============================================================================
# LEVE — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to git.
# =============================================================================

# --- App ---
NODE_ENV=development

# --- Next.js (web) ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- API (Fastify) ---
PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# Session — generate with: openssl rand -hex 32
SESSION_COOKIE_SECRET=change_me_to_a_random_32_char_string_xxx
SESSION_COOKIE_NAME=leve_sid

# --- Database ---
DATABASE_URL=postgresql://leve:leve_dev_password@localhost:5432/leve_db

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- AWS ---
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=leve-assets
AWS_CLOUDFRONT_DOMAIN=cdn.leve.am
AWS_CLOUDFRONT_KEY_PAIR_ID=K2ABC123XYZ
# Private key — paste content of cloudfront-private-key.pem
# Replace actual newlines with \n for single-line env value:
AWS_CLOUDFRONT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----

# Amazon Translate — uses existing AWS credentials above.
# IAM policy must include: { "Action": ["translate:TranslateText"], "Resource": "*" }
AWS_TRANSLATE_ENABLED=false

# --- AI: fal.ai (primary — FLUX.1 Kontext handles all generation) ---
FAL_API_KEY=

# Not used — FLUX Kontext handles all generation
# REPLICATE_API_TOKEN=

# --- Payments: Idram (primary) ---
IDRAM_MERCHANT_ID=
IDRAM_SECRET_KEY=

# --- Payments: Telcell (secondary) ---
TELCELL_MERCHANT_ID=
TELCELL_SECRET_KEY=

# --- Payments: ArCa (Visa/MC via Armenian bank) ---
# ARCA_MERCHANT_ID=
# ARCA_SECRET_KEY=
# ARCA_API_URL=

# --- OTP delivery via AWS SNS (SMS) and SES (email) ---
# Uses existing AWS credentials above. Required in production; skipped in dev (codes logged to console).
# IAM policy must include: sns:Publish, ses:SendEmail
AWS_SNS_SENDER_ID=LEVE
AWS_SES_FROM_EMAIL=noreply@leve.am
AWS_SES_FROM_NAME=LEVE
